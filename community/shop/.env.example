# Community Shop - Environment Variables

# Amazon Affiliate
AMAZON_ASSOCIATOR_ID=your_associator_id
AMAZON_TAG=your_tag.xsi
AMAZON_DOMAIN=www.amazon.de

# Datenbank
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=community_shop
DB_USERNAME=root
DB_PASSWORD=your_password

# E-Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@community-shop.de
SMTP_PASS=your_smtp_password

# Sicherheit
APP_ENV=local
APP_DEBUG=true
APP_KEY=your_app_key_here

# Session
SESSION_LIFETIME=7200
SESSION_SECURE=false

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_SECONDS=60
