{
    "name": "chris1971nrw/community-shop",
    "description": "E-Commerce Plattform für deine Community",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "psr/container": "^1.1",
        "psr/http-message": "^2.0",
        "symfony/http-foundation": "^7.0",
        "slim/slim": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "CommunityShop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CommunityShop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "cs": "phpcs",
        "phpstan": "phpstan analyse"
    }
}
